generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int            @id @default(autoincrement())
  first_name          String
  last_name           String
  email               String         @unique
  phone               String?
  license_plate       String?
  password_hash       String
  subscription_status String         @default("inactive")
  role                String         @default("customer")  // "customer" | "admin"
  created_at          DateTime       @default(now())

  orders              Order[]
  subscriptions       Subscription[]
  passwordResetTokens PasswordResetToken[]
}

model Order {
  id           Int       @id @default(autoincrement())
  user_id      Int?
  items        Json                           // JSONB in PostgreSQL
  total_amount Decimal   @db.Decimal(10, 2)
  status       String    @default("pending")  // pending | arrived | ready | completed
  created_at   DateTime  @default(now())
  ready_time   DateTime?

  guest_first_name          String?
  guest_last_name           String?
  guest_email               String?
  guest_phone               String?
  guest_license_plate       String?
  stripe_payment_intent_id  String?

  subscription_id  Int?
  subscription     Subscription? @relation(fields: [subscription_id], references: [id], onDelete: SetNull)

  user         User?     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([status])
  @@index([guest_email])
  @@index([subscription_id])
}

model Subscription {
  id               Int      @id @default(autoincrement())
  user_id          Int
  tier             String   @default("drink")  // "drink" | "combo"
  pickup_time      String   @default("08:00")  // "HH:MM" local time
  start_date       DateTime
  end_date         DateTime
  weekly_allowance Decimal  @db.Decimal(10, 2)
  used_amount      Decimal  @db.Decimal(10, 2) @default(0)
  default_items    Json?    // For automated daily order generation

  user             User     @relation(fields: [user_id], references: [id])
  orders           Order[]

  @@unique([user_id])
  @@index([end_date])
}

model MenuItem {
  id          Int     @id @default(autoincrement())
  name        String
  price       Decimal @db.Decimal(10, 2)
  description String?
  image_url   String?
  category    String? // "hot" | "cold" | "food"
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id])

  @@index([token])
  @@index([user_id])
}
